#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="$ROOT/bin"
SKILL_NAMES=(manage-codex-workers codex-review)
PROFILE="${WORKERCTL_INSTALL_PROFILE:-$HOME/.zshrc}"
CODEX_HOME_DIR="${CODEX_HOME:-$HOME/.codex}"
PATH_LINE="export PATH=\"$BIN_DIR:\$PATH\""
INSTALL_SKILL=true

usage() {
  cat <<EOF
Usage: scripts/install-local [--write] [--profile PATH] [--codex-home PATH] [--no-skill]

Print or install the local workerctl PATH setup and Codex skills.

Options:
  --write           Append the PATH line and install the skill.
  --profile PATH    Shell profile to update. Defaults to ~/.zshrc.
  --codex-home PATH Codex home directory. Defaults to \$CODEX_HOME or ~/.codex.
  --no-skill        Skip installing Codex skills.
  -h, --help        Show this help.
EOF
}

write=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --write)
      write=true
      shift
      ;;
    --profile)
      if [[ $# -lt 2 ]]; then
        echo "install-local: --profile requires a path" >&2
        exit 1
      fi
      PROFILE="$2"
      shift 2
      ;;
    --codex-home)
      if [[ $# -lt 2 ]]; then
        echo "install-local: --codex-home requires a path" >&2
        exit 1
      fi
      CODEX_HOME_DIR="$2"
      shift 2
      ;;
    --no-skill)
      INSTALL_SKILL=false
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "install-local: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ ! -x "$BIN_DIR/workerctl" ]]; then
  echo "install-local: expected executable not found: $BIN_DIR/workerctl" >&2
  exit 1
fi

if [[ "$INSTALL_SKILL" == true ]]; then
  for skill_name in "${SKILL_NAMES[@]}"; do
    skill_src="$ROOT/skills/$skill_name"
    if [[ ! -f "$skill_src/SKILL.md" ]]; then
      echo "install-local: expected skill not found: $skill_src/SKILL.md" >&2
      exit 1
    fi
    if [[ "$skill_name" == "codex-review" && ! -x "$skill_src/scripts/codex-review" ]]; then
      echo "install-local: expected executable helper not found: $skill_src/scripts/codex-review" >&2
      exit 1
    fi
  done
fi

if [[ "$write" == false ]]; then
  echo "$PATH_LINE"
  echo
  if [[ "$INSTALL_SKILL" == true ]]; then
    echo "Skill install targets:"
    for skill_name in "${SKILL_NAMES[@]}"; do
      echo "  $CODEX_HOME_DIR/skills/$skill_name"
    done
    echo
  fi
  echo "Dispatch setup:"
  echo "  workerctl dispatch --watch --dispatcher-id dispatch-local"
  echo "  workerctl qa-plan dispatch-completion"
  echo
  echo "To install for zsh:"
  echo "  scripts/install-local --write"
  echo
  echo "To use in the current shell:"
  echo "  $PATH_LINE"
  exit 0
fi

mkdir -p "$(dirname "$PROFILE")"
touch "$PROFILE"

if grep -Fqx "$PATH_LINE" "$PROFILE"; then
  echo "workerctl PATH already installed in $PROFILE"
else
  {
    echo
    echo "# codex-terminal-manager"
    echo "$PATH_LINE"
  } >> "$PROFILE"
  echo "installed workerctl PATH in $PROFILE"
fi

PATH="$BIN_DIR:$PATH" workerctl classify --text "workerctl install check" >/dev/null || {
  echo "install-local: workerctl verification failed after PATH update" >&2
  exit 1
}

if [[ "$INSTALL_SKILL" == true ]]; then
  for skill_name in "${SKILL_NAMES[@]}"; do
    skill_src="$ROOT/skills/$skill_name"
    skill_dest="$CODEX_HOME_DIR/skills/$skill_name"
    mkdir -p "$(dirname "$skill_dest")"
    rm -rf "$skill_dest"
    cp -R "$skill_src" "$skill_dest"
    if [[ "$skill_name" == "codex-review" ]]; then
      chmod +x "$skill_dest/scripts/codex-review"
    fi
    echo "installed $skill_name skill in $skill_dest"
  done
fi

echo "workerctl is available after opening a new shell, or immediately with:"
echo "  $PATH_LINE"
if [[ "$INSTALL_SKILL" == true ]]; then
  echo "Plain Codex sessions can use the installed manage-codex-workers and codex-review skills after starting a new session."
fi
echo "Start Dispatch when supervising a pair so worker completion wakes the manager:"
echo "  workerctl dispatch --watch --dispatcher-id dispatch-local"
echo "For a bounded verification flow:"
echo "  workerctl qa-plan dispatch-completion"
