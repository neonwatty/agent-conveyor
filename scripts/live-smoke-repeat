#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WORKERCTL="${ROOT}/scripts/workerctl"
COUNT="${1:-3}"
RUN_ID="repeat-$(date +%Y%m%d%H%M%S)"
ARTIFACT_ROOT="${ROOT}/docs/live-qa-artifacts/$(date +%Y-%m-%d)-live-smoke-repeat-${RUN_ID}"
SUMMARY="${ARTIFACT_ROOT}/summary.jsonl"

if ! [[ "${COUNT}" =~ ^[0-9]+$ ]] || [ "${COUNT}" -lt 1 ]; then
  echo "usage: scripts/live-smoke-repeat [positive-count]" >&2
  exit 2
fi

mkdir -p "${ARTIFACT_ROOT}"
cd "${ROOT}"

echo "repeat artifact root: ${ARTIFACT_ROOT}"
echo "repeat count: ${COUNT}"

run_capture() {
  local name="$1"
  local status
  shift

  set +e
  "$@" > "${run_dir}/${name}.stdout" 2> "${run_dir}/${name}.stderr"
  status="$?"
  set -e

  printf '%s\n' "${status}" > "${run_dir}/${name}.exit"
  return "${status}"
}

for index in $(seq 1 "${COUNT}"); do
  run_dir="${ARTIFACT_ROOT}/run-${index}"
  mkdir -p "${run_dir}"
  echo "live smoke repeat run ${index}/${COUNT}"

  set +e
  scripts/live-smoke > "${run_dir}/live-smoke.stdout" 2> "${run_dir}/live-smoke.stderr"
  status="$?"
  set -e
  printf '%s\n' "${status}" > "${run_dir}/live-smoke.exit"

  run_capture "sessions-active" "${WORKERCTL}" sessions --state active
  run_capture "reconcile" "${WORKERCTL}" reconcile --stale-cycles-seconds 1

  node - "${index}" "${status}" "${run_dir}/live-smoke.stdout" "${run_dir}/reconcile.stdout" >> "${SUMMARY}" <<'JS'
const fs = require("fs");

const index = Number(process.argv[2]);
const status = Number(process.argv[3]);
const stdout = fs.readFileSync(process.argv[4], "utf8");
const reconcile = JSON.parse(fs.readFileSync(process.argv[5], "utf8"));
const lineValue = (prefix) => {
  const line = stdout.split(/\r?\n/).find((candidate) => candidate.startsWith(prefix));
  return line ? line.slice(prefix.length) : null;
};
const record = {
  run: index,
  status,
  artifact_root: lineValue("artifact root: "),
  worker: lineValue("smoke worker: "),
  manager: lineValue("smoke manager: "),
  reconcile_clean: !(
    reconcile.dangling_bindings
    || reconcile.dead_pid_sessions
    || reconcile.stuck_tasks
  ),
};
console.log(JSON.stringify(record));
JS

  if [ "${status}" -ne 0 ]; then
    echo "live smoke repeat failed on run ${index}; see ${run_dir}" >&2
    exit "${status}"
  fi

  node - "${run_dir}/live-smoke.stdout" "${run_dir}/sessions-active.stdout" <<'JS'
const fs = require("fs");

const stdout = fs.readFileSync(process.argv[2], "utf8");
const sessions = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
const lineValue = (prefix) => {
  const line = stdout.split(/\r?\n/).find((candidate) => candidate.startsWith(prefix));
  return line ? line.slice(prefix.length) : null;
};
const names = new Set([lineValue("smoke worker: "), lineValue("smoke manager: ")].filter(Boolean));
const active = new Set(sessions.map((session) => session.name));
const leftovers = [...names].filter((name) => active.has(name)).sort();
if (leftovers.length) {
  throw new Error(`live smoke sessions still active: ${JSON.stringify(leftovers)}`);
}
JS

  node - "${run_dir}/reconcile.stdout" <<'JS'
const fs = require("fs");

const data = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
for (const key of ["dangling_bindings", "dead_pid_sessions", "stuck_tasks"]) {
  if (data[key]) {
    throw new Error(`reconcile reported ${key}: ${JSON.stringify(data[key])}`);
  }
}
JS
done

echo "live smoke repeat passed"
