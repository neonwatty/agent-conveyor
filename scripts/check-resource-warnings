#!/usr/bin/env node
import { spawnSync } from "node:child_process";

const args = process.argv.slice(2);
const command = args[0] === "--" ? args.slice(1) : ["npm", "test", "--", "--runInBand"];

if (command.length === 0) {
  console.error("usage: check-resource-warnings [-- command ...]");
  process.exit(2);
}

const result = spawnSync(command[0], command.slice(1), {
  encoding: "utf8",
  stdio: ["inherit", "pipe", "pipe"],
});

process.stdout.write(result.stdout ?? "");
process.stderr.write(result.stderr ?? "");

if (result.status !== 0) {
  process.exit(result.status ?? 1);
}

const combined = `${result.stdout ?? ""}\n${result.stderr ?? ""}`;
if (combined.includes("ResourceWarning")) {
  console.error("ResourceWarning detected in command output");
  process.exit(1);
}
