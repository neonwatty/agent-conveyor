#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
SMOKE_DIR="$(mktemp -d "$TMP_ROOT/agent-conveyor-package-smoke.XXXXXX")"

cleanup() {
  rm -rf "$SMOKE_DIR"
}
trap cleanup EXIT

PACK_JSON="$SMOKE_DIR/npm-pack.json"
PREFIX="$SMOKE_DIR/prefix"
CODEX_HOME_DIR="$SMOKE_DIR/codex-home"

(
  cd "$SMOKE_DIR"
  npm pack "$ROOT" --json > "$PACK_JSON"
)

TARBALL="$SMOKE_DIR/$(node - "$PACK_JSON" <<'NODE'
const fs = require("node:fs");
const pack = JSON.parse(fs.readFileSync(process.argv[2], "utf8"))[0];
process.stdout.write(pack.filename);
NODE
)"

node - "$PACK_JSON" <<'NODE'
const fs = require("node:fs");
const pack = JSON.parse(fs.readFileSync(process.argv[2], "utf8"))[0];
const files = new Map(pack.files.map((file) => [file.path, file]));
const required = [
  "dist/cli/main.js",
  "dist/index.js",
  "scripts/serve-landing-page.mjs",
  "README.md",
  "docs/landing-page.html",
  "docs/manager-recipes.md",
  "skills/manage-codex-workers/SKILL.md",
  "skills/codex-review/SKILL.md",
  "skills/codex-review/scripts/codex-review",
];
for (const path of required) {
  if (!files.has(path)) {
    throw new Error(`npm tarball missing required file: ${path}`);
  }
}
for (const path of ["skills/codex-review/scripts/codex-review"]) {
  if (files.get(path).mode !== 0o755) {
    throw new Error(`npm tarball file is not executable: ${path}`);
  }
}
for (const path of files.keys()) {
  if (
    path === "scripts/workerctl"
    || /^workerctl\/.*\.py$/.test(path)
    || /^dist\/cli\/python-bridge\.(?:js|d\.ts|js\.map)$/.test(path)
  ) {
    throw new Error(`npm tarball contains Python runtime/bridge file: ${path}`);
  }
}
NODE

echo "== TypeScript migration audit =="
node "$ROOT/scripts/ts-migration-audit.mjs" --require-zero-python --pack-json="$PACK_JSON"

npm install -g --prefix "$PREFIX" "$TARBALL"

CONVEYOR="$PREFIX/bin/conveyor"
WORKERCTL="$PREFIX/bin/workerctl"

conveyor_help="$(PATH="$PREFIX/bin:$PATH" "$CONVEYOR" --help | head -n 1)"
workerctl_help="$(PATH="$PREFIX/bin:$PATH" "$WORKERCTL" --help | head -n 1)"

case "$conveyor_help" in
  "usage: conveyor"*) ;;
  *)
    echo "package-smoke: expected conveyor help to start with 'usage: conveyor', got: $conveyor_help" >&2
    exit 1
    ;;
esac

case "$workerctl_help" in
  "usage: workerctl"*) ;;
  *)
    echo "package-smoke: expected workerctl help to start with 'usage: workerctl', got: $workerctl_help" >&2
    exit 1
    ;;
esac

CODEX_HOME="$CODEX_HOME_DIR" PATH="$PREFIX/bin:$PATH" "$CONVEYOR" install-skills --codex-home "$CODEX_HOME_DIR" --json > "$SMOKE_DIR/install-skills.json"

node - "$SMOKE_DIR/install-skills.json" "$CODEX_HOME_DIR" <<'JS'
const fs = require("fs");
const path = require("path");

const receiptPath = process.argv[2];
const codexHome = process.argv[3];
const receipt = JSON.parse(fs.readFileSync(receiptPath, "utf8"));
const skillNames = new Set(receipt.skills.map((row) => row.name));
const missing = ["manage-codex-workers", "codex-review"].filter((name) => !skillNames.has(name));
if (missing.length) {
  throw new Error(`missing installed skills: ${JSON.stringify(missing)}`);
}

const manageSkill = path.join(codexHome, "skills", "manage-codex-workers", "SKILL.md");
const reviewSkill = path.join(codexHome, "skills", "codex-review", "SKILL.md");
const reviewHelper = path.join(codexHome, "skills", "codex-review", "scripts", "codex-review");
for (const candidate of [manageSkill, reviewSkill, reviewHelper]) {
  if (!fs.existsSync(candidate)) {
    throw new Error(`expected installed asset missing: ${candidate}`);
  }
}
try {
  fs.accessSync(reviewHelper, fs.constants.X_OK);
} catch {
  throw new Error(`expected executable helper: ${reviewHelper}`);
}

const copyableLegacyCommand = /scripts\/(?:workerctl|conveyor)|converyor|workerctl\s+(?:dispatch|qa-plan|cycle|worker-inbox|manager-inbox|update-status|criteria|replay|audit|telemetry|export-task|bind|pair|status|list)\b/;
const match = fs.readFileSync(manageSkill, "utf8").match(copyableLegacyCommand);
if (match) {
  throw new Error(`installed manage-codex-workers skill contains stale command text: ${JSON.stringify(match[0])}`);
}
JS

SMOKE_DB="$SMOKE_DIR/app-loop.db"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" create-disposable-binding smoke-app-loop \
  --worker smoke-worker \
  --manager smoke-manager \
  --worker-codex-app-thread-id thread-worker-smoke \
  --worker-codex-app-thread-title "Smoke Worker" \
  --manager-codex-app-thread-id thread-manager-smoke \
  --manager-codex-app-thread-title "Smoke Manager" \
  --adversarial \
  --path "$SMOKE_DB" \
  --json > "$SMOKE_DIR/create-disposable-binding.json"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" app-heartbeat smoke-app-loop --role manager --path "$SMOKE_DB" --json > "$SMOKE_DIR/app-heartbeat-manager.json"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" app-heartbeat smoke-app-loop --role worker --path "$SMOKE_DB" --json > "$SMOKE_DIR/app-heartbeat-worker.json"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" dispatch --watch --watch-iterations 1 --dispatcher-id dispatch-local --path "$SMOKE_DB" --json > "$SMOKE_DIR/dispatch-watch.json"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" app-loop-status smoke-app-loop --path "$SMOKE_DB" --json > "$SMOKE_DIR/app-loop-status.json"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" app-wakeup-plan smoke-app-loop --path "$SMOKE_DB" --json > "$SMOKE_DIR/app-wakeup-plan.json"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" app-wakeup-dispatch smoke-app-loop --path "$SMOKE_DB" --json > "$SMOKE_DIR/app-wakeup-dispatch-healthy.json"

STALE_DB="$SMOKE_DIR/app-loop-stale.db"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" create-disposable-binding smoke-app-stale \
  --worker smoke-stale-worker \
  --manager smoke-stale-manager \
  --worker-codex-app-thread-id thread-worker-stale \
  --worker-codex-app-thread-title "Smoke Stale Worker" \
  --manager-codex-app-thread-id thread-manager-stale \
  --manager-codex-app-thread-title "Smoke Stale Manager" \
  --adversarial \
  --path "$STALE_DB" \
  --json > "$SMOKE_DIR/create-disposable-binding-stale.json"
node - "$STALE_DB" <<'JS'
const { DatabaseSync } = require("node:sqlite");
const database = new DatabaseSync(process.argv[2]);
try {
  database.prepare("update sessions set last_heartbeat_at = '2026-01-01T00:00:00Z'").run();
} finally {
  database.close();
}
JS
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" app-wakeup-dispatch smoke-app-stale --path "$STALE_DB" --json > "$SMOKE_DIR/app-wakeup-dispatch-stale.json"
STALE_RECEIPT="$(node -e "process.stdout.write(JSON.parse(require('fs').readFileSync(process.argv[1], 'utf8')).receipt.event_id)" "$SMOKE_DIR/app-wakeup-dispatch-stale.json")"
HEALTHY_RECEIPT="$(node -e "process.stdout.write(JSON.parse(require('fs').readFileSync(process.argv[1], 'utf8')).receipt.event_id)" "$SMOKE_DIR/app-wakeup-dispatch-healthy.json")"
PATH="$PREFIX/bin:$PATH" "$CONVEYOR" app-wakeup-record-delivery smoke-app-stale \
  --role manager \
  --dispatch-receipt "$STALE_RECEIPT" \
  --delivery-status sent \
  --thread-id thread-manager-stale \
  --reason "package smoke adapter sent" \
  --path "$STALE_DB" \
  --json > "$SMOKE_DIR/app-wakeup-delivery-sent.json"
if PATH="$PREFIX/bin:$PATH" "$CONVEYOR" app-wakeup-record-delivery smoke-app-loop \
  --role manager \
  --dispatch-receipt "$HEALTHY_RECEIPT" \
  --delivery-status sent \
  --thread-id thread-manager-smoke \
  --path "$SMOKE_DB" \
  --json > "$SMOKE_DIR/app-wakeup-delivery-rejected.json" 2> "$SMOKE_DIR/app-wakeup-delivery-rejected.err"; then
  echo "package-smoke: expected healthy skipped action to reject sent delivery" >&2
  exit 1
fi

node - "$SMOKE_DIR/create-disposable-binding.json" "$SMOKE_DIR/app-loop-status.json" "$SMOKE_DIR/app-wakeup-plan.json" "$SMOKE_DIR/app-wakeup-dispatch-healthy.json" "$SMOKE_DIR/app-wakeup-dispatch-stale.json" "$SMOKE_DIR/app-wakeup-delivery-sent.json" "$SMOKE_DIR/app-wakeup-delivery-rejected.err" <<'JS'
const fs = require("fs");
const binding = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const status = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
const wakeup = JSON.parse(fs.readFileSync(process.argv[4], "utf8"));
const healthyDispatch = JSON.parse(fs.readFileSync(process.argv[5], "utf8"));
const staleDispatch = JSON.parse(fs.readFileSync(process.argv[6], "utf8"));
const deliverySent = JSON.parse(fs.readFileSync(process.argv[7], "utf8"));
const deliveryRejected = fs.readFileSync(process.argv[8], "utf8");
if (!binding.heartbeat_recommendations?.wakeup_dispatch_command?.includes("app-wakeup-dispatch 'smoke-app-loop'")) {
  throw new Error(`expected bootstrap wakeup dispatch command, got ${JSON.stringify(binding.heartbeat_recommendations)}`);
}
if (!binding.heartbeat_recommendations.delivery_receipt_commands?.sent?.includes("--delivery-status sent --thread-id <action.thread.id>")) {
  throw new Error(`expected sent delivery receipt template, got ${JSON.stringify(binding.heartbeat_recommendations.delivery_receipt_commands)}`);
}
if (!binding.heartbeat_recommendations.delivery_receipt_commands?.skipped?.includes("--delivery-status skipped")) {
  throw new Error(`expected skipped delivery receipt template, got ${JSON.stringify(binding.heartbeat_recommendations.delivery_receipt_commands)}`);
}
if (!binding.heartbeat_recommendations.delivery_receipt_commands?.blocked?.includes("--delivery-status blocked")) {
  throw new Error(`expected blocked delivery receipt template, got ${JSON.stringify(binding.heartbeat_recommendations.delivery_receipt_commands)}`);
}
if (!binding.heartbeat_recommendations.manager?.prompt?.includes("send_ready=true") || !binding.heartbeat_recommendations.manager.prompt.includes("app-wakeup-record-delivery")) {
  throw new Error(`expected manager bootstrap prompt to include wake dispatch delivery receipt guidance, got ${JSON.stringify(binding.heartbeat_recommendations.manager?.prompt)}`);
}
if (!status.ok) {
  throw new Error(`expected healthy app-loop status, got ${JSON.stringify(status.next_actions)}`);
}
if (status.dispatch.state !== "healthy" || status.manager.lease.state !== "healthy" || status.worker.lease.state !== "healthy") {
  throw new Error(`expected healthy dispatch/manager/worker leases, got ${JSON.stringify(status)}`);
}
if (!Array.isArray(wakeup.wakeups) || wakeup.wakeups.length !== 0) {
  throw new Error(`expected no wakeups for healthy loop, got ${JSON.stringify(wakeup.wakeups)}`);
}
if (healthyDispatch.summary.ready_to_send !== 0 || healthyDispatch.summary.skipped !== 2 || healthyDispatch.dispatcher.required) {
  throw new Error(`expected healthy wake dispatch to skip both roles, got ${JSON.stringify(healthyDispatch.summary)}`);
}
if (staleDispatch.summary.ready_to_send !== 2 || staleDispatch.summary.skipped !== 0) {
  throw new Error(`expected stale wake dispatch to prepare both roles, got ${JSON.stringify(staleDispatch.summary)}`);
}
if (!staleDispatch.dispatcher.required || staleDispatch.dispatcher.state !== "missing") {
  throw new Error(`expected stale wake dispatch to preserve missing dispatch requirement, got ${JSON.stringify(staleDispatch.dispatcher)}`);
}
if (!staleDispatch.actions.every((action) => action.status === "ready_to_send" && action.send_ready && action.prompt)) {
  throw new Error(`expected stale wake dispatch actions to be send-ready with prompts, got ${JSON.stringify(staleDispatch.actions)}`);
}
if (staleDispatch.receipt.event_type !== "app_wakeup_dispatch_planned") {
  throw new Error(`expected wake dispatch telemetry receipt, got ${JSON.stringify(staleDispatch.receipt)}`);
}
if (deliverySent.delivery.status !== "sent" || deliverySent.delivery.source_action_status !== "ready_to_send" || !deliverySent.delivery.source_send_ready) {
  throw new Error(`expected sent delivery receipt for ready action, got ${JSON.stringify(deliverySent.delivery)}`);
}
if (deliverySent.source.dispatch_receipt !== staleDispatch.receipt.event_id || !deliverySent.source.dispatch_required) {
  throw new Error(`expected delivery to link stale dispatch receipt and preserve dispatch requirement, got ${JSON.stringify(deliverySent.source)}`);
}
if (!/Cannot record sent wakeup for manager; source action is skipped_healthy/.test(deliveryRejected)) {
  throw new Error(`expected rejected healthy sent receipt, got ${JSON.stringify(deliveryRejected)}`);
}
JS

echo "package-smoke: npm tarball exposes conveyor and workerctl, and bundled skills are valid"
