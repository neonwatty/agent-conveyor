#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/agent-conveyor-release-check.XXXXXX")"

cleanup() {
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT

PACK_JSON="$WORK_DIR/npm-pack.json"
PREFIX="$WORK_DIR/prefix"
CODEX_HOME_DIR="$WORK_DIR/codex-home"

echo "== npm build =="
npm --prefix "$ROOT" run build

echo "== npm pack =="
(
  cd "$WORK_DIR"
  npm pack "$ROOT" --json > "$PACK_JSON"
)

TARBALL="$WORK_DIR/$(node - "$PACK_JSON" <<'NODE'
const fs = require("node:fs");
const pack = JSON.parse(fs.readFileSync(process.argv[2], "utf8"))[0];
process.stdout.write(pack.filename);
NODE
)"

node - "$PACK_JSON" "$ROOT/package.json" <<'NODE'
const fs = require("node:fs");
const pack = JSON.parse(fs.readFileSync(process.argv[2], "utf8"))[0];
const manifest = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
if (manifest.private === true) {
  throw new Error("package.json is still private");
}
if (manifest.name !== "agent-conveyor") {
  throw new Error(`unexpected package name: ${manifest.name}`);
}
if (manifest.scripts?.prepublishOnly !== "node scripts/prepublish-guard.mjs") {
  throw new Error("prepublishOnly guard is missing or changed");
}
if (!manifest.bin?.conveyor || !manifest.bin?.workerctl) {
  throw new Error("package bins must expose conveyor and workerctl");
}
const files = new Map(pack.files.map((file) => [file.path, file]));
const required = [
  manifest.bin.conveyor.replace(/^\.\//, ""),
  manifest.bin.workerctl.replace(/^\.\//, ""),
  "scripts/serve-landing-page.mjs",
  "README.md",
  "docs/landing-page.html",
  "docs/manager-recipes.md",
  "skills/manage-codex-workers/SKILL.md",
  "skills/codex-review/SKILL.md",
  "skills/codex-review/scripts/codex-review",
  "plugin/agent-conveyor/plugin.json",
  "plugin/agent-conveyor/skills/conveyor-app-wake-relay/SKILL.md",
  "plugin/agent-conveyor/skills/conveyor-smoke-app-connections/SKILL.md",
  "plugin/agent-conveyor/skills/conveyor-create-pair/SKILL.md",
  "plugin/agent-conveyor/skills/conveyor-create-worker-set/SKILL.md",
  "plugin/agent-conveyor/skills/conveyor-check-status/SKILL.md",
  "plugin/agent-conveyor/skills/conveyor-whats-next-nudger/SKILL.md",
];
for (const path of required) {
  if (!files.has(path)) {
    throw new Error(`release tarball missing required file: ${path}`);
  }
}
for (const path of ["skills/codex-review/scripts/codex-review"]) {
  if (files.get(path).mode !== 0o755) {
    throw new Error(`release tarball file is not executable: ${path}`);
  }
}
for (const path of files.keys()) {
  if (
    path === "scripts/workerctl"
    || /^workerctl\/.*\.py$/.test(path)
    || /^dist\/cli\/python-bridge\.(?:js|d\.ts|js\.map)$/.test(path)
  ) {
    throw new Error(`release tarball contains Python runtime/bridge file: ${path}`);
  }
}
NODE

echo "== TypeScript migration audit =="
node "$ROOT/scripts/ts-migration-audit.mjs" --require-zero-python --pack-json="$PACK_JSON"

echo "== clean npm install smoke =="
npm install -g --prefix "$PREFIX" "$TARBALL"

CONVEYOR="$PREFIX/bin/conveyor"
WORKERCTL="$PREFIX/bin/workerctl"

conveyor_help="$(PATH="$PREFIX/bin:$PATH" "$CONVEYOR" --help | head -n 1)"
workerctl_help="$(PATH="$PREFIX/bin:$PATH" "$WORKERCTL" --help | head -n 1)"

case "$conveyor_help" in
  "usage: conveyor"*) ;;
  *)
    echo "release-check: expected conveyor --help to start with 'usage: conveyor', got: $conveyor_help" >&2
    exit 1
    ;;
esac

case "$workerctl_help" in
  "usage: workerctl"*) ;;
  *)
    echo "release-check: expected workerctl --help to start with 'usage: workerctl', got: $workerctl_help" >&2
    exit 1
    ;;
esac

CODEX_HOME="$CODEX_HOME_DIR" PATH="$PREFIX/bin:$PATH" "$CONVEYOR" install-skills --codex-home "$CODEX_HOME_DIR" --json > "$WORK_DIR/install-skills.json"

node - "$WORK_DIR/install-skills.json" "$CODEX_HOME_DIR" <<'JS'
const fs = require("fs");
const path = require("path");

const receiptPath = process.argv[2];
const codexHome = process.argv[3];
const receipt = JSON.parse(fs.readFileSync(receiptPath, "utf8"));
const skillNames = new Set(receipt.skills.map((row) => row.name));
const missing = ["manage-codex-workers", "codex-review"].filter((name) => !skillNames.has(name));
if (missing.length) {
  throw new Error(`missing installed skills: ${JSON.stringify(missing)}`);
}

const reviewHelper = path.join(codexHome, "skills", "codex-review", "scripts", "codex-review");
for (const candidate of [
  path.join(codexHome, "skills", "manage-codex-workers", "SKILL.md"),
  path.join(codexHome, "skills", "codex-review", "SKILL.md"),
  reviewHelper,
]) {
  if (!fs.existsSync(candidate)) {
    throw new Error(`expected installed asset missing: ${candidate}`);
  }
}
try {
  fs.accessSync(reviewHelper, fs.constants.X_OK);
} catch {
  throw new Error(`expected executable helper: ${reviewHelper}`);
}
JS

CODEX_HOME="$CODEX_HOME_DIR" PATH="$PREFIX/bin:$PATH" "$CONVEYOR" install-plugin --codex-home "$CODEX_HOME_DIR" --json > "$WORK_DIR/install-plugin.json"
CODEX_HOME="$CODEX_HOME_DIR" PATH="$PREFIX/bin:$PATH" "$CONVEYOR" plugin-status --codex-home "$CODEX_HOME_DIR" --json > "$WORK_DIR/plugin-status.json"

node - "$WORK_DIR/install-plugin.json" "$WORK_DIR/plugin-status.json" "$CODEX_HOME_DIR" <<'JS'
const fs = require("fs");
const path = require("path");

const installPlugin = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const pluginStatus = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
const codexHome = process.argv[4];
const expectedSkills = [
  "conveyor-app-wake-relay",
  "conveyor-check-status",
  "conveyor-create-pair",
  "conveyor-create-worker-set",
  "conveyor-smoke-app-connections",
  "conveyor-whats-next-nudger",
];

if (installPlugin.package_version !== installPlugin.plugin_version) {
  throw new Error(`expected plugin version to match package version, got ${installPlugin.plugin_version} vs ${installPlugin.package_version}`);
}
if (installPlugin.installed !== true) {
  throw new Error(`expected install-plugin to report installed=true, got ${JSON.stringify(installPlugin.installed)}`);
}
const installedSkills = [...installPlugin.installed_skills].sort();
if (JSON.stringify(installedSkills) !== JSON.stringify(expectedSkills)) {
  throw new Error(`expected installed plugin skills ${JSON.stringify(expectedSkills)}, got ${JSON.stringify(installedSkills)}`);
}
if (pluginStatus.version_matches !== true) {
  throw new Error(`expected plugin-status version_matches=true, got ${JSON.stringify(pluginStatus.version_matches)}`);
}

const versionedManifest = path.join(
  codexHome,
  "plugins",
  "cache",
  "agent-conveyor",
  "agent-conveyor",
  installPlugin.package_version,
  "plugin.json",
);
if (!fs.existsSync(versionedManifest)) {
  throw new Error(`expected installed plugin manifest missing: ${versionedManifest}`);
}
for (const skill of expectedSkills) {
  const skillPath = path.join(codexHome, "skills", skill, "SKILL.md");
  if (!fs.existsSync(skillPath)) {
    throw new Error(`expected installed plugin skill missing: ${skillPath}`);
  }
}
JS

echo "== Release check receipt =="
printf 'tarball=%s\n' "$TARBALL"
printf 'conveyor_help=%s\n' "$conveyor_help"
printf 'workerctl_help=%s\n' "$workerctl_help"
echo "release-check: packed npm tarball, installed it in a clean prefix, verified bundled skills, and verified plugin install/status without publishing"
