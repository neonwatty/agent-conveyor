#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/agent-conveyor-release-check.XXXXXX")"
ROOT_EGG_INFO="$ROOT/agent_conveyor.egg-info"
ROOT_EGG_INFO_PREEXISTED=0
if [[ -e "$ROOT_EGG_INFO" ]]; then
  ROOT_EGG_INFO_PREEXISTED=1
fi

cleanup() {
  if [[ "$ROOT_EGG_INFO_PREEXISTED" == "0" ]]; then
    rm -rf "$ROOT_EGG_INFO"
  fi
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT

BUILD_VENV="$WORK_DIR/build-venv"
INSTALL_VENV="$WORK_DIR/install-venv"
DIST_DIR="$WORK_DIR/dist"
CODEX_HOME_DIR="$WORK_DIR/codex-home"
BUILD_LOG="$WORK_DIR/build.log"

python3 -m venv "$BUILD_VENV"
BUILD_PYTHON="$BUILD_VENV/bin/python"
"$BUILD_PYTHON" -m pip install --upgrade pip build twine

echo "== build clean distributions =="
set +e
"$BUILD_PYTHON" -m build --outdir "$DIST_DIR" "$ROOT" >"$BUILD_LOG" 2>&1
build_status=$?
set -e
cat "$BUILD_LOG"
if [[ "$build_status" -ne 0 ]]; then
  echo "release-check: build failed" >&2
  exit "$build_status"
fi

if grep -E "SetuptoolsDeprecationWarning|Package would be ignored" "$BUILD_LOG" >/dev/null; then
  echo "release-check: build produced packaging warnings" >&2
  exit 1
fi

echo "== twine check =="
"$BUILD_PYTHON" -m twine check "$DIST_DIR"/*

shopt -s nullglob
wheels=("$DIST_DIR"/*.whl)
sdists=("$DIST_DIR"/*.tar.gz)
shopt -u nullglob
if [[ "${#wheels[@]}" -ne 1 ]]; then
  echo "release-check: expected exactly one wheel, found ${#wheels[@]}" >&2
  exit 1
fi
if [[ "${#sdists[@]}" -ne 1 ]]; then
  echo "release-check: expected exactly one sdist, found ${#sdists[@]}" >&2
  exit 1
fi

python3 -m venv "$INSTALL_VENV"
INSTALL_PYTHON="$INSTALL_VENV/bin/python"
CONVEYOR="$INSTALL_VENV/bin/conveyor"
WORKERCTL="$INSTALL_VENV/bin/workerctl"
"$INSTALL_PYTHON" -m pip install --upgrade pip
"$INSTALL_PYTHON" -m pip install "${wheels[0]}"

echo "== installed CLI smoke =="
conveyor_help="$("$CONVEYOR" --help | head -n 1)"
workerctl_help="$("$WORKERCTL" --help | head -n 1)"

case "$conveyor_help" in
  "usage: conveyor"*) ;;
  *)
    echo "release-check: expected conveyor --help to start with 'usage: conveyor', got: $conveyor_help" >&2
    exit 1
    ;;
esac

case "$workerctl_help" in
  "usage: workerctl"*) ;;
  *)
    echo "release-check: expected workerctl --help to start with 'usage: workerctl', got: $workerctl_help" >&2
    exit 1
    ;;
esac

"$CONVEYOR" install-skills --codex-home "$CODEX_HOME_DIR" --json > "$WORK_DIR/install-skills.json"

"$INSTALL_PYTHON" - "$WORK_DIR/install-skills.json" "$CODEX_HOME_DIR" <<'PY'
import json
import os
import sys
from pathlib import Path

receipt_path = Path(sys.argv[1])
codex_home = Path(sys.argv[2])
receipt = json.loads(receipt_path.read_text())
skill_names = {row["name"] for row in receipt["skills"]}
expected = {"manage-codex-workers", "codex-review"}
missing = expected - skill_names
if missing:
    raise SystemExit(f"missing installed skills: {sorted(missing)}")

review_helper = codex_home / "skills" / "codex-review" / "scripts" / "codex-review"
for path in (
    codex_home / "skills" / "manage-codex-workers" / "SKILL.md",
    codex_home / "skills" / "codex-review" / "SKILL.md",
    review_helper,
):
    if not path.exists():
        raise SystemExit(f"expected installed asset missing: {path}")
if not os.access(review_helper, os.X_OK):
    raise SystemExit(f"expected executable helper: {review_helper}")
PY

echo "== Release check receipt =="
printf 'wheel=%s\n' "${wheels[0]}"
printf 'sdist=%s\n' "${sdists[0]}"
printf 'conveyor_help=%s\n' "$conveyor_help"
printf 'workerctl_help=%s\n' "$workerctl_help"
echo "release-check: built clean distributions, passed twine check, installed the wheel, and verified bundled skills"
