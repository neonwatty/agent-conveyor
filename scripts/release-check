#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/agent-conveyor-release-check.XXXXXX")"

cleanup() {
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT

PACK_JSON="$WORK_DIR/npm-pack.json"
PREFIX="$WORK_DIR/prefix"
CODEX_HOME_DIR="$WORK_DIR/codex-home"

echo "== npm build =="
npm --prefix "$ROOT" run build

echo "== npm pack =="
(
  cd "$WORK_DIR"
  npm pack "$ROOT" --json > "$PACK_JSON"
)

TARBALL="$WORK_DIR/$(node - "$PACK_JSON" <<'NODE'
const fs = require("node:fs");
const pack = JSON.parse(fs.readFileSync(process.argv[2], "utf8"))[0];
process.stdout.write(pack.filename);
NODE
)"

node - "$PACK_JSON" "$ROOT/package.json" <<'NODE'
const fs = require("node:fs");
const pack = JSON.parse(fs.readFileSync(process.argv[2], "utf8"))[0];
const manifest = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
if (manifest.private === true) {
  throw new Error("package.json is still private");
}
if (manifest.name !== "agent-conveyor") {
  throw new Error(`unexpected package name: ${manifest.name}`);
}
if (manifest.scripts?.prepublishOnly !== "node scripts/prepublish-guard.mjs") {
  throw new Error("prepublishOnly guard is missing or changed");
}
if (!manifest.bin?.conveyor || !manifest.bin?.workerctl) {
  throw new Error("package bins must expose conveyor and workerctl");
}
const files = new Map(pack.files.map((file) => [file.path, file]));
const required = [
  manifest.bin.conveyor.replace(/^\.\//, ""),
  manifest.bin.workerctl.replace(/^\.\//, ""),
  "scripts/workerctl",
  "workerctl/assets/skills/manage-codex-workers/SKILL.md",
  "workerctl/assets/skills/codex-review/SKILL.md",
  "workerctl/assets/skills/codex-review/scripts/codex-review",
];
for (const path of required) {
  if (!files.has(path)) {
    throw new Error(`release tarball missing required file: ${path}`);
  }
}
for (const path of [
  "scripts/workerctl",
  "workerctl/assets/skills/codex-review/scripts/codex-review",
]) {
  if (files.get(path).mode !== 0o755) {
    throw new Error(`release tarball file is not executable: ${path}`);
  }
}
NODE

echo "== TypeScript migration audit =="
node "$ROOT/scripts/ts-migration-audit.mjs" --pack-json="$PACK_JSON"

echo "== clean npm install smoke =="
npm install -g --prefix "$PREFIX" "$TARBALL"

CONVEYOR="$PREFIX/bin/conveyor"
WORKERCTL="$PREFIX/bin/workerctl"

conveyor_help="$(PATH="$PREFIX/bin:$PATH" "$CONVEYOR" --help | head -n 1)"
workerctl_help="$(PATH="$PREFIX/bin:$PATH" "$WORKERCTL" --help | head -n 1)"

case "$conveyor_help" in
  "usage: conveyor"*) ;;
  *)
    echo "release-check: expected conveyor --help to start with 'usage: conveyor', got: $conveyor_help" >&2
    exit 1
    ;;
esac

case "$workerctl_help" in
  "usage: workerctl"*) ;;
  *)
    echo "release-check: expected workerctl --help to start with 'usage: workerctl', got: $workerctl_help" >&2
    exit 1
    ;;
esac

CODEX_HOME="$CODEX_HOME_DIR" PATH="$PREFIX/bin:$PATH" "$CONVEYOR" install-skills --codex-home "$CODEX_HOME_DIR" --json > "$WORK_DIR/install-skills.json"

python3 - "$WORK_DIR/install-skills.json" "$CODEX_HOME_DIR" <<'PY'
import json
import os
import sys
from pathlib import Path

receipt_path = Path(sys.argv[1])
codex_home = Path(sys.argv[2])
receipt = json.loads(receipt_path.read_text())
skill_names = {row["name"] for row in receipt["skills"]}
expected = {"manage-codex-workers", "codex-review"}
missing = expected - skill_names
if missing:
    raise SystemExit(f"missing installed skills: {sorted(missing)}")

review_helper = codex_home / "skills" / "codex-review" / "scripts" / "codex-review"
for path in (
    codex_home / "skills" / "manage-codex-workers" / "SKILL.md",
    codex_home / "skills" / "codex-review" / "SKILL.md",
    review_helper,
):
    if not path.exists():
        raise SystemExit(f"expected installed asset missing: {path}")
if not os.access(review_helper, os.X_OK):
    raise SystemExit(f"expected executable helper: {review_helper}")
PY

echo "== Release check receipt =="
printf 'tarball=%s\n' "$TARBALL"
printf 'conveyor_help=%s\n' "$conveyor_help"
printf 'workerctl_help=%s\n' "$workerctl_help"
echo "release-check: packed npm tarball, installed it in a clean prefix, and verified bundled skills without publishing"
